{
  "name": "printpoz-desktop-designer",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop edition (Electron + TypeScript) of the Printpoz/CODNIX photo editor.",
  "author": "Printpoz / CODNIX",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "@react-three/drei": "^9.119.0",
    "@react-three/fiber": "^8.17.10",
    "@reduxjs/toolkit": "^2.2.6",
    "@teokamali/react-image-loader": "^1.4.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.7.4",
    "bootstrap": "^5.3.3",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.8.9",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.11",
    "html2canvas": "^1.4.1",
    "jqeury": "^0.0.1-security",
    "jspdf": "^3.0.3",
    "jszip": "^3.10.1",
    "leva": "^0.9.35",
    "loadable-image": "^3.2.6",
    "openai": "^4.77.0",
    "pako": "^2.1.0",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.4",
    "react-color": "^2.19.3",
    "react-device-detect": "^2.2.3",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-dropdown-select": "^4.11.3",
    "react-icons": "^5.2.1",
    "react-lazyload": "^3.2.1",
    "react-moveable": "^0.56.0",
    "react-pageflip": "^2.0.3",
    "react-redux": "^9.1.2",
    "react-responsive-masonry": "^2.7.1",
    "react-router-dom": "^6.24.0",
    "react-scripts": "^5.0.1",
    "react-step-wizard": "^5.3.11",
    "react-toastify": "^11.0.5",
    "redux-undo": "^1.1.0",
    "socket.io-client": "^4.8.1",
    "styled-components": "^6.1.11",
    "swiper": "^11.1.5",
    "three": "^0.171.0",
    "turn.js": "^1.0.2",
    "uuid": "^10.0.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node -e \"process.env.CI='false'; require('react-scripts/scripts/build')\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build:electron": "node scripts/build-electron.mjs",
    "watch:electron": "node scripts/build-electron.mjs --watch",
    "typecheck:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k -n CRA,ELECTRON -c blue,green \"cross-env BROWSER=none react-scripts start\" \"npm run electron:dev:app\"",
    "electron:dev:app": "wait-on tcp:127.0.0.1:3000 && npm run build:electron && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "electron:start": "npm run build:electron && electron .",
    "electron:build": "npm run build && npm run build:electron",
    "dist": "npm run electron:build && electron-builder",
    "dist:win": "npm run electron:build && electron-builder --win",
    "dist:mac": "npm run electron:build && electron-builder --mac"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}